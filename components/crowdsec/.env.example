# CrowdSec 环境变量（所有变量已有内置默认值）
# 生产环境务必覆盖所有 *_KEY / *_PASSWORD：
#   openssl rand -hex 32

# APISIX bouncer key（APISIX crowdsec-lapi 插件调 LAPI 用；P2 启用）
CROWDSEC_BOUNCER_KEY=changeme-generate-a-real-bouncer-key
# platform-admin 作为 bouncer 读 /v1/decisions
CROWDSEC_PLATFORM_ADMIN_BOUNCER_KEY=polaris-dev-bouncer-platform-admin
# platform-admin 作为 machine 登录（读 alerts / 写 decision / 删除 decision）
CROWDSEC_AGENT_USERNAME=platform-admin
CROWDSEC_AGENT_PASSWORD=polaris-dev-agent-password
