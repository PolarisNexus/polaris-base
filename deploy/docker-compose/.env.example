# ==================================================
# polaris-base 基础设施环境变量模板
# 使用方式: cp .env.example .env 然后修改实际值
# ==================================================

# ---------- PostgreSQL ----------
POSTGRES_USER=polaris
POSTGRES_PASSWORD=changeme
POSTGRES_DB=polaris
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# ---------- Elasticsearch ----------
ES_PORT=9200
ES_SECURITY_ENABLED=false
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ---------- MinIO ----------
MINIO_ROOT_USER=polaris
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
