# 生产环境覆盖样板
# 使用方式: cp docker-compose.override.yml.prod.example docker-compose.override.yml

services:
  elasticsearch:
    environment:
      ELASTIC_PASSWORD: ${ELASTIC_PASSWORD:?ELASTIC_PASSWORD required in prod}

  elasticsearch-otel:
    environment:
      ELASTIC_PASSWORD: ${ELASTIC_OTEL_PASSWORD:?ELASTIC_OTEL_PASSWORD required in prod}
