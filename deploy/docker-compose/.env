# 默认激活全部 plane。按需启动时在命令行覆盖，例如：
#   COMPOSE_PROFILES=data docker compose up -d
COMPOSE_PROFILES=data,platform,services

# ---- 跨服务对齐的凭据（dev 默认；生产改为 Secret）----
# APISIX Admin API Key（components/apisix/config.yaml 内置同值 fallback）
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1
# Elasticsearch basic auth（components/elastic 内置同值 fallback）
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=E&9xV2#pM7@zQ4!y
# CrowdSec machine 凭据：两侧 compose 读同一个变量，保持一致
CROWDSEC_AGENT_USERNAME=platform-admin
CROWDSEC_AGENT_PASSWORD=polaris-dev-agent-password
# CrowdSec bouncer 凭据：LAPI /v1/decisions 读路径需要 X-Api-Key
CROWDSEC_PLATFORM_ADMIN_BOUNCER_KEY=polaris-dev-bouncer-platform-admin
