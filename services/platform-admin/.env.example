# platform-admin 后端环境变量
HTTP_ADDR=:8080
APISIX_ADMIN_URL=http://apisix:9180
# 必填：与 components/apisix/config.yaml 中 deployment.admin.admin_key 对齐
APISIX_ADMIN_KEY=edd1c9f034335f136f87ad84b625c8f1
ELASTIC_URL=http://elasticsearch:9200
# 必填：与 components/elastic/.env 中 ELASTIC_PASSWORD 对齐（BFF 用 elastic 超级账号只读查攻击日志）
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=E&9xV2#pM7@zQ4!y
CROWDSEC_LAPI_URL=http://crowdsec:8080
# machine 凭据：读 alerts / 写 decision / 删除 decision（走 /v1/watchers/login 拿 JWT）
CROWDSEC_USERNAME=platform-admin
CROWDSEC_PASSWORD=polaris-dev-agent-password
# bouncer 凭据：读 /v1/decisions（LAPI 用 X-Api-Key 区分 machine 与 bouncer）
CROWDSEC_BOUNCER_KEY=polaris-dev-bouncer-platform-admin

# OIDC（Authentik，ADR-0013 单点登录）
# issuer 末尾保留 /；与 Authentik Provider 的 OpenID Configuration Issuer 一致
OIDC_ISSUER=http://authentik-server:9000/application/o/platform-admin/
OIDC_CLIENT_ID=polaris-platform-admin
# 放行前端开发服务器
ALLOWED_CORS_ORIGIN=http://localhost:5173
# 仅本地调试用，生产禁止开启
# AUTH_DISABLED=1
